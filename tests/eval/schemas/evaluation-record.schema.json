{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "callpilot-eval-result-v1",
  "title": "CallPilot unified evaluation result",
  "type": "object",
  "required": [
    "evaluation_version",
    "run_id",
    "dataset",
    "split",
    "scenario_id",
    "source_id",
    "source_type",
    "provider",
    "model",
    "model_parameters",
    "input_snapshot",
    "available_transcript",
    "available_screen_context",
    "raw_model_output",
    "parsed_output",
    "recovered_output",
    "final_rendered_output",
    "raw_model_pass",
    "parsed_pass",
    "recovered_pass",
    "retry_count",
    "repair_events",
    "deterministic_scores",
    "execution_scores",
    "judge_scores",
    "latency",
    "failure_class",
    "severity",
    "artifacts"
  ],
  "additionalProperties": true,
  "properties": {
    "evaluation_version": { "const": "callpilot-eval-result-v1" },
    "split": { "enum": ["development", "validation", "holdout"] },
    "retry_count": { "type": "number", "minimum": 0 },
    "repair_events": { "type": "array" }
  }
}
