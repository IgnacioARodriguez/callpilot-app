{
  "conversationAssist": {
    "maxWords": 130,
    "semanticChecks": {
      "naturalSpokenTone": true,
      "noCodeBlock": true,
      "noLongCode": true,
      "dequeTestsPlan": true
    }
  },
  "codingWorkspace": {
    "expectedFunction": "count_event_types",
    "mustContain": [
      "from collections import deque",
      "deque",
      "popleft",
      "assert",
      "sorted",
      "counts.items()"
    ],
    "mustContainAny": [
      "-item[1]",
      "-pair[1]",
      "reverse=True"
    ],
    "mustPreserve": [
      "count_event_types",
      "seen_ids",
      "recent_events",
      "counts"
    ],
    "mustNotContain": [
      "pop(0)",
      "pytest",
      "unittest",
      "input("
    ],
    "semanticExpectations": [
      "Debe optimizar la cola de eventos recientes con deque y popleft.",
      "Debe mantener set y deque sincronizados al expirar eventos.",
      "Debe incluir asserts para duplicado dentro de ventana, duplicado despues de expirar, malformed input y sorting.",
      "Debe explicar complejidad sin cambiar el contrato final."
    ],
    "semanticChecks": {
      "sortedEventMetrics": true,
      "usesDequeWindow": true
    },
    "pythonAssertions": [
      "events = ['0|a1|click', '10|a1|view', 'bad line', '301|a1|purchase', '302|b2|click', '303|c3|view']",
      "assert count_event_types(events) == [('click', 2), ('purchase', 1), ('view', 1)]"
    ]
  }
}
