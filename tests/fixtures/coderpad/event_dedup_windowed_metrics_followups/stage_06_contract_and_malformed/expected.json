{
  "conversationAssist": {
    "maxWords": 130,
    "semanticChecks": {
      "naturalSpokenTone": true,
      "noCodeBlock": true,
      "noLongCode": true,
      "malformedSortingPlan": true
    }
  },
  "codingWorkspace": {
    "expectedFunction": "count_event_types",
    "mustContain": [
      "def count_event_types(lines):",
      "try",
      "except",
      "continue",
      "sorted",
      "counts.items()"
    ],
    "mustContainAny": [
      "-item[1]",
      "-pair[1]",
      "reverse=True"
    ],
    "mustPreserve": [
      "recent_events",
      "seen_ids",
      "counts",
      "event_type"
    ],
    "mustNotContain": [
      "deque",
      "popleft",
      "raise",
      "input(",
      "pytest",
      "unittest"
    ],
    "semanticExpectations": [
      "Debe ignorar lineas malformadas sin lanzar.",
      "Debe cambiar el retorno a lista de tuplas ordenada por count desc y tipo asc.",
      "Debe conservar la logica de ventana y set.",
      "No debe introducir deque todavia."
    ],
    "semanticChecks": {
      "sortedEventMetrics": true
    },
    "pythonAssertions": [
      "events = ['0|a1|click', 'bad line', '10|b2|view', '301|a1|purchase', '302|c3|click']",
      "assert count_event_types(events) == [('click', 2), ('purchase', 1), ('view', 1)]"
    ]
  }
}
