{
  "conversationAssist": {
    "maxWords": 130,
    "semanticChecks": {
      "naturalSpokenTone": true,
      "noCodeBlock": true,
      "noLongCode": true,
      "perceivesTerminalFailure": true,
      "usesPriorVisualContext": true
    }
  },
  "codingWorkspace": {
    "expectedFunction": "format_user",
    "mustPreserve": ["def format_user(name):"],
    "mustContain": ["strip", "split", "join", "title"],
    "mustNotContain": ["upper()", "unittest", "pytest"],
    "semanticChecks": {
      "preservesVisibleSignature": true,
      "doesNotCopyTestsIntoImplementation": true,
      "updatesImplementationNotTests": true
    },
    "pythonAssertions": [
      "assert format_user(' ada   lovelace ') == 'Ada Lovelace'",
      "assert format_user('GRACE hopper') == 'Grace Hopper'",
      "assert format_user('') == 'Anonymous'"
    ]
  }
}
