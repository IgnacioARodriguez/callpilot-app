# Copy to .env and fill locally.
NVIDIA_API_KEY=
CALLPILOT_NVIDIA_API_KEY=
CALLPILOT_NVIDIA_LLM_URL=https://integrate.api.nvidia.com/v1/chat/completions
CALLPILOT_NVIDIA_MODEL=meta/llama-3.1-8b-instruct
